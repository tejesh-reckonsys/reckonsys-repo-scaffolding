# App
APP_ENV=development
DEBUG=true
SECRET_KEY=changeme

# Server
HOST=0.0.0.0
PORT=8000

# OpenTelemetry (leave blank to disable)
OTEL_SERVICE_NAME={{ project_name }}
OTEL_EXPORTER_OTLP_ENDPOINT=

# Caddy (host port for docker-compose)
CADDY_PORT={{ caddy_port }}
{% if use_postgres %}
# Postgres
POSTGRES_PORT={{ postgres_port }}
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:{{ postgres_port }}/{{ project_name }}
{% endif %}
{% if use_worker %}
# Redis
REDIS_PORT={{ redis_port }}
REDIS_URL=redis://localhost:{{ redis_port }}
{% endif %}
