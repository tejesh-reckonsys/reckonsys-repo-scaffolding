{% if use_worker %}
import orjson
import structlog
from arq.connections import RedisSettings

from app.core.config import settings
from app.core.logging import setup_logging

setup_logging()

logger = structlog.get_logger()


async def startup(ctx: dict) -> None:
    {% if not bare %}
    # Initialize shared resources here, accessible in all tasks via ctx.
    # Example: ctx["http"] = httpx.AsyncClient()
    {% endif %}
    logger.info("worker starting")


async def shutdown(ctx: dict) -> None:
    {% if not bare %}
    # Clean up shared resources here.
    # Example: await ctx["http"].aclose()
    {% endif %}
    logger.info("worker stopping")

{% if not bare %}

async def setup_user(ctx: dict, *, user_id: int, user_name: str, email: str) -> dict:
    """
    Example arq task to run on creating user.

    Enqueue from a FastAPI route:
        await request.app.state.arq.enqueue_job(
            "setup_user",
            user_id=user_id,
            user_name=user_name,
            email=email,
        )

    Access shared resources set up in startup via ctx:
        http: httpx.AsyncClient = ctx["http"]
    """
    logger.info("Setting up user", user_id=user_id, user_name=user_name, email=email)
    return {"status": "success"}
    

{% endif %}

def job_serializer(data):
    return orjson.dumps(data)

def job_deserializer(data: bytes):
    return orjson.loads(data.decode())

class WorkerSettings:
    redis_settings = RedisSettings.from_dsn(settings.REDIS_URL)
    functions = [{% if not bare %}setup_user{% endif %}]
    on_startup = startup
    on_shutdown = shutdown
    job_serializer = job_serializer
    job_deserializer = job_deserializer
{% endif %}
