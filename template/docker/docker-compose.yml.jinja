services:
  caddy:
    image: caddy:2-alpine
    ports:
      - "${CADDY_PORT:-{{ caddy_port }}}:80"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
    depends_on:
      - app

  app:
    build:
      context: ..
      dockerfile: Dockerfile
    env_file: .env
    expose:
      - "8000"
    {% if use_postgres or use_worker %}
    depends_on:
      {% if use_postgres %}
      db:
        condition: service_healthy
      {% endif %}
      {% if use_worker %}
      redis:
        condition: service_healthy
      {% endif %}
    {% endif %}

{% if use_postgres %}
  db:
    image: postgres:16
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: {{ project_name }}
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5
{% endif %}

{% if use_worker %}
  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 5
{% endif %}

{% if use_postgres or use_worker %}
volumes:
  {% if use_postgres %}
  postgres_data:
  {% endif %}
{% endif %}
