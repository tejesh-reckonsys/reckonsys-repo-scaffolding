name: {{ project_name }}-prod

services:
  caddy:
    image: caddy:2-alpine
    container_name: {{ project_name }}-prod-caddy
    ports:
      - "${CADDY_PORT:-{{ caddy_port }}}:80"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
    depends_on:
      - app

  app:
    container_name: {{ project_name }}-prod-app
    build:
      context: ../..
      dockerfile: Dockerfile
    env_file: ../../.env
    command: ["api"]
    volumes:
      - ./logs:/app/logs
    environment:
      APP_ENV: production
      DEBUG: "false"
      LOG_TO_FILE: "true"
      LOG_PATH: "/app/logs/worker.log"
      SERVICE_NAME: "app"
      {% if use_postgres -%}
      DATABASE_URL: postgresql+asyncpg://postgres:postgres@db:5432/{{ project_name }}
      {% endif -%}
      {% if use_worker -%}
      REDIS_URL: redis://redis:6379
      {% endif -%}
    expose:
      - "8000"
    depends_on:
      migrate:
        condition: service_completed_successfully
      {% if use_postgres -%}
      db:
        condition: service_healthy
      {%- endif %}

  {% if use_worker -%}
  worker:
    container_name: {{ project_name }}-prod-worker
    build:
      context: ../..
      dockerfile: Dockerfile
    env_file: ../../.env
    command: ["worker"]
    volumes:
      - ./logs:/app/logs
    environment:
      APP_ENV: production
      DEBUG: "false"
      LOG_TO_FILE: "true"
      LOG_PATH: "/app/logs/worker.log"
      SERVICE_NAME: "worker"
      {% if use_postgres -%}
      DATABASE_URL: postgresql+asyncpg://postgres:postgres@db:5432/{{ project_name }}
      {% endif -%}
      REDIS_URL: redis://redis:6379
    depends_on:
      migrate:
        condition: service_completed_successfully
      {% if use_postgres -%}
      db:
        condition: service_healthy
      {% endif -%}
      redis:
        condition: service_healthy
  {%- endif %}

  {% if use_postgres -%}
  db:
    image: postgres:18
    container_name: {{ project_name }}-prod-postgres
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: {{ project_name }}
    volumes:
      - postgres_data:/var/lib/postgresql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 10
  {%- endif %}

  {% if use_worker -%}
  redis:
    image: redis:8-alpine
    container_name: {{ project_name }}-prod-redis
    volumes:
      - redis_data:/data
    command: ["redis-server", "--appendonly", "yes"]
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 10
  {%- endif %}

  {% if use_postgres -%}
  migrate:
    container_name: {{ project_name }}-prod-migrate
    build:
      context: ../..
      dockerfile: Dockerfile
    env_file: ../../.env
    command: ["migrate"]
    volumes:
      - ./logs:/app/logs
    environment:
      APP_ENV: production
      DEBUG: "false"
      LOG_TO_FILE: "true"
      LOG_PATH: "/app/logs/migrate.log"
      SERVICE_NAME: "migrate"
      DATABASE_URL: postgresql+asyncpg://postgres:postgres@db:5432/{{ project_name }}
    depends_on:
      db:
        condition: service_healthy
  {%- endif %}


volumes:
  {% if use_postgres -%}
  postgres_data:
  {% endif -%}
  {% if use_worker -%}
  redis_data:
  {%- endif %}

