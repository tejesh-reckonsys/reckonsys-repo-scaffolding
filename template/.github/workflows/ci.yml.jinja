name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: astral-sh/setup-uv@v4
        with:
          python-version: "{{ python_version }}"

      - name: Install dependencies (locked)
        run: uv sync --frozen

      - name: Lint
        run: make lint

      - name: Format check
        run: make format

  test:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - uses: astral-sh/setup-uv@v4
        with:
          python-version: "{{ python_version }}"

      - name: Verify Docker
        run: docker version

      - name: Install dependencies (locked)
        run: uv sync --frozen

      - name: Run tests (via docker compose)
        run: make test
